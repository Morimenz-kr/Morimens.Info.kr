.card-name {
    z-index: 3;
    top: 12px; /* ◀ 요청대로 top: 12px로 수정 */
    left: 50%;
    transform: translateX(-50%);
    width: 65%; /* ◀ 너비 조정으로 코스트 영역 침범 방지 */
    font-size: 1.5em;
    font-weight: 700;
    color: #fff;
