#stats-table-container li:last-child { border: none; }
#stats-table-container b { float: right; color: #fff; }

/* (스킬 카드 CSS) */
.skill-carousel-container { display: flex; align-items: center; justify-content: space-between; }
.skill-card-builder { position: relative; width: 300px; height: 465px; flex-shrink: 0; margin: 0 auto; opacity: 1; transition: opacity 0.15s ease-in-out; background-color: #222; border-radius: 10px; overflow: hidden; }
.skill-card-builder.fading { opacity: 0; }
