<file path="css/responsive.css">
/* ============================================
   반응형 스타일 (Responsive Design)
   모든 페이지에 적용되는 반응형 미디어 쿼리
   ============================================ */

/* =============================================
   브레이크포인트:
   - 모바일 소형: ~ 480px
   - 모바일 일반: 481px ~ 600px  
   - 태블릿 세로: 601px ~ 768px
   - 태블릿 가로: 769px ~ 1024px
   - PC: 1025px ~
   ============================================= */

/* --- 모바일 소형 (~ 480px) --- */
@media (max-width: 480px) {

    /* 공통 */
    .container {
        padding: 15px;
    }

    /* Landing (index.html) */
    .landing-container {
        padding: 20px 15px 60px;
    }

    header h1 {
        font-size: 1.4em;
    }

    header {
        margin-bottom: 20px;
    }

    .banner-container {
        margin-bottom: 25px;
    }

    .banner-text {
        font-size: 1.1em;
    }

    .banner-tag {
        font-size: 0.75em;
        padding: 3px 6px;
    }

    .arrow svg {
        width: 28px;
        height: 28px;
    }

    /* 메뉴 그리드: 2열 */
    .menu-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }

    .menu-item {
        font-size: 1.8em;
        border-radius: 10px;
    }

    .menu-label {
        font-size: 0.85em;
    }

    footer {
        font-size: 0.7em;
    }

    /* List (list.html) */
    .header-area h1 {
        font-size: 1.3em;
        padding: 0 70px;
    }

    .header-area .back-link {
        padding: 6px 10px;
        font-size: 0.75em;
    }

    .controls-container {
        flex-direction: column;
        gap: 10px;
    }

    .filter-container {
        justify-content: space-between;
    }

    select {
        flex: 1;
        font-size: 0.9em;
        padding: 10px;
    }

    .character-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }

    .character-card h3 {
        font-size: 0.95em;
    }

    /* Links (links.html) - 모바일 소형 북마크 축소 */
    .notion-bookmark {
        height: auto;
        min-height: 80px;
    }

    .bookmark-image {
        width: 80px;
        height: 80px;
    }

    .bookmark-content {
        padding: 8px 10px;
    }

    .bookmark-title {
        font-size: 0.95em;
    }

    .bookmark-desc {
        font-size: 0.85em;
    }

    .category-title {
        font-size: 1.4em;
    }

    /* Detail (detail.html) - 모바일 레이아웃 */
    .detail-layout {
        flex-direction: column;
        gap: 20px;
    }

    .char-profile,
    .char-data {
        flex-basis: 100%;
    }

    .data-tabs {
        overflow-x: auto;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
    }

    .data-tabs .tab-link {
        font-size: 0.95em;
        padding: 8px 12px;
    }

    .skill-card-builder {
        width: 100%;
        max-width: 280px;
        height: auto;
        aspect-ratio: 300 / 465;
    }

    .team-cards-wrapper {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }
}

/* --- 모바일 일반 (481px ~ 600px) --- */
@media (min-width: 481px) and (max-width: 600px) {
    .container {
        padding: 15px;
    }

    .landing-container {
        padding: 20px 15px 60px;
    }

    header h1 {
        font-size: 1.5em;
    }

    header {
        margin-bottom: 20px;
    }

    .banner-container {
        margin-bottom: 30px;
    }

    .arrow svg {
        width: 30px;
        height: 30px;
    }

    /* 메뉴 그리드: 3열 */
    .menu-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .menu-item {
        font-size: 1.4em;
        border-radius: 10px;
    }

    .menu-label {
        font-size: 0.9em;
    }

    footer {
        font-size: 0.75em;
    }

    /* List */
    .header-area h1 {
        font-size: 1.4em;
    }

    .controls-container {
        flex-direction: column;
    }

    .character-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    /* Links - 북마크 크기 조정 */
    .notion-bookmark {
        height: auto;
        min-height: 100px;
    }

    .bookmark-image {
        width: 100px;
        height: 100px;
    }

    /* Detail */
    .detail-layout {
        flex-direction: column;
    }

    .team-cards-wrapper {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* --- 태블릿 세로 (601px ~ 768px) --- */
@media (min-width: 601px) and (max-width: 768px) {

    /* 메뉴 그리드: 3열 */
    .menu-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .menu-item {
        font-size: 1.8em;
    }

    /* 배너 높이는 landing.css에서 clamp()로 처리 */

    /* List */
    .character-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }

    /* Links */
    .notion-bookmark {
        height: 120px;
    }

    .bookmark-image {
        width: 120px;
        height: 120px;
    }

    /* Detail */
    .detail-layout {
        flex-direction: column;
    }

    .team-cards-wrapper {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* --- 태블릿 가로 (769px ~ 1024px) --- */
@media (min-width: 769px) and (max-width: 1024px) {

    /* 메뉴 그리드: 4열 */
    .menu-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .menu-item {
        font-size: 2em;
    }

    /* List */
    .character-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    /* Detail */
    .team-cards-wrapper {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* --- PC (1025px ~) --- */
@media (min-width: 1025px) {

    /* 메뉴 그리드: 4열 */
    .menu-grid {
        grid-template-columns: repeat(4, 1fr);
    }

    /* List - auto-fill로 자동 조정 */
    .character-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    /* Detail */
    .team-cards-wrapper {
        grid-template-columns: repeat(4, 1fr);
    }
}

/* --- 유동 타이포그래피 --- */
h1 { font-size: clamp(1.4em, 3vw, 2.2em); }
header h1 { font-size: clamp(1.4em, 3vw, 2.2em); }
.category-title { font-size: clamp(1.4em, 3vw, 2em); }

/* --- 가로 모드 폰 대응 --- */
@media (orientation: landscape) and (max-height: 500px) {
    .banner-container { margin-bottom: 15px; }
    .landing-container { padding-top: 20px; padding-bottom: 40px; }
    .menu-grid { gap: 8px; }
    .menu-item { aspect-ratio: 2 / 0.7; font-size: 1.6em; }
    .modal-content { max-height: 90vh; }
}

/* --- 공통 터치 디바이스 최적화 --- */
@media (hover: none) and (pointer: coarse) {

    /* 터치 타겟 크기 증가 */
    .menu-item {
        min-height: 60px;
    }

    button,
    a.back-link,
    .menu-wrapper {
        min-height: 44px;
        /* iOS 권장 최소 터치 영역 */
    }

    /* 호버 효과 비활성화 (터치 기기에서는 불필요) */
    .character-card:hover,
    .notion-bookmark:hover,
    .menu-wrapper:hover .menu-item {
        transform: none;
    }
}

/* --- 다크모드 지원 (선택적) --- */
@media (prefers-color-scheme: dark) {
    /* 기본이 이미 다크모드이므로 추가 조정 불필요 */
    /* 필요시 라이트모드 사용자를 위한 스타일 추가 가능 */
}

/* --- 인쇄 스타일 (선택적) --- */
@media print {

    .bg-image,
    .background-overlay,
    footer,
    .back-link,
    .arrow,
    .dots-container {
        display: none !important;
    }

    body {
        background: white;
        color: black;
    }

    .container {
        max-width: 100%;
    }
}
/* --- 모바일 추천 세팅: 정렬 및 크기 강제 보정 (인라인 스타일 무력화) --- */
@media (max-width: 768px) {
    /* 1. 전체 박스 설정 */
    .recommend-box {
        flex-direction: column !important;
        aspect-ratio: auto !important;
        height: auto !important;
    }

    /* 2. 상단 (썸네일/태그) 중앙 정렬 */
    .recommend-left {
        width: 100% !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        border-right: none !important;
        border-bottom: 1px solid #444 !important;
        padding: 20px !important;
        text-align: center !important;
    }

    /* 3. 하단 (명륜/비밀계약) 그리드 설정 */
    .recommend-right {
        width: 100% !important;
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 25px 10px !important;
        padding: 25px 15px !important;
        align-items: start !important;
    }

    /* 4. 🚨 인라인 스타일(가로 배치) 강제 해제 및 중앙 정렬 */
    .recommend-right > div {
        display: flex !important;
        flex-direction: column !important; /* 가로(Row)에서 세로(Column)로 강제 변경 */
        align-items: center !important;    /* 가로축 중앙 정렬 */
        justify-content: center !important;
        text-align: center !important;     /* 텍스트 중앙 정렬 */
        width: 100% !important;
        gap: 10px !important;              /* 이미지와 글자 사이 간격 */
    }

    /* 5. 비밀계약 전체 너비 및 강조 */
    .recommend-right > div:last-child {
        grid-column: 1 / -1 !important;
        border-top: 1px dashed #444 !important;
        padding-top: 20px !important;
        margin-top: 10px !important;
    }

    /* 6. 이미지 크기 보정 */
    .equip-img-myeongryun {
        width: 80px !important;
        height: auto !important;
    }

    .equip-img-covenant {
        width: 100% !important;
        max-width: 160px !important; /* 🔥 비밀계약 이미지 대폭 확대 */
        height: auto !important;
        margin: 0 auto !important;
    }

    /* 7. 내부 텍스트 박스 중앙 정렬 */
    .equip-info-myeongryun,
    .equip-info-covenant {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important; /* 글자 박스 안의 내용들도 중앙으로 */
        width: 100% !important;
    }

    /* 상세 텍스트들 개별 정렬 */
    .equip-info-myeongryun span,
    .equip-info-covenant span {
        text-align: center !important;
        display: block !important;
        width: 100% !important;
    }
}
