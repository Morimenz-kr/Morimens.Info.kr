/* ============================================
   index.html 전용 스타일 (Landing Page)
   ============================================ */

/* --- 1. 메인 레이아웃 컨테이너 --- */
.landing-container {
    position: relative;
    z-index: 999;
    width: 100%;
    max-width: 800px;
    padding: 40px 20px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    margin: 0 auto;
}

/* --- 2. 헤더 --- */
header {
    flex: 0 0 auto;
    width: 100%;
    text-align: center;
    margin-bottom: 40px;
}

header h1 {
    margin: 0;
    color: #fff;
    font-size: 2.2em;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    word-break: keep-all;
}

/* --- 3. 배너 슬라이더 --- */
.banner-container {
    flex: 0 0 auto;
    position: relative;
    width: 100%;
    height: clamp(100px, 15vw, 160px);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
    border: 1px solid #555;
    margin-bottom: 45px;
}

.banner-track {
    display: flex;
    width: 100%;
    height: 100%;
}

.banner-slide {
    min-width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    color: white;
    position: relative;
    overflow: hidden;
}

.banner-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.6);
    transition: filter 0.2s;
}

.banner-slide:hover img {
    filter: brightness(0.8);
}

.banner-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    text-align: center;
    width: 100%;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.8);
    pointer-events: none;
}

.banner-tag {
    background: #ffc107;
    color: #000;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: bold;
    font-size: 0.9em;
    margin-right: 8px;
    vertical-align: middle;
}

.banner-text {
    font-size: 1.4em;
    font-weight: bold;
    color: #fff;
    vertical-align: middle;
}

/* 배너 화살표 */
.arrow {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(36px, 6vw, 50px);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
}

.arrow:hover {
    background: rgba(0, 0, 0, 0.2);
}

.arrow svg {
    width: 40px;
    height: 40px;
    stroke: rgba(255, 255, 255, 0.6);
    transition: stroke 0.2s, transform 0.2s;
}

.arrow:hover svg {
    stroke: #ffc107;
    transform: scale(1.1);
}

.arrow.left {
    left: 0;
}

.arrow.right {
    right: 0;
}

/* 배너 도트 */
.dots-container {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
}

.dot {
    width: 8px;
    height: 8px;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s;
}

.dot.active {
    background: #fff;
    transform: scale(1.2);
    width: 20px;
    border-radius: 4px;
}

/* --- 4. 메뉴 그리드 래퍼 --- */
.menu-grid-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

/* --- 5. 푸터 --- */
footer {
    flex: 0 0 auto;
    width: 100%;
    max-width: 800px;
    text-align: center;
    font-size: 0.8em;
    color: #888;
    padding: 15px 20px 10px;
    margin: 0 auto;
}

.patch-link {
    color: #999;
    text-decoration: underline;
    cursor: pointer;
}

.patch-link:hover {
    color: #ffc107;
}

/* --- 6. 패치노트 모달 전용 스타일 --- */
.patch-list {
    overflow-y: auto;
    padding-right: 5px;
}

.patch-item {
    margin-bottom: 15px;
}

.patch-ver {
    font-weight: bold;
    color: #eee;
}

.patch-date {
    font-size: 0.8em;
    color: #777;
    margin-left: 5px;
}

.patch-desc {
    margin: 5px 0 0 0;
    padding-left: 15px;
    color: #ccc;
    font-size: 0.85em;
}

/* =========================================
   2x1 와이드 메뉴 (높이 1배 유지, 가로 2배 확장)
   ========================================= */

/* 1. 컨테이너: 가로 2칸 차지 + 텍스트는 무조건 아래로 */
.menu-grid .menu-wrapper.wide-menu {
    grid-column: span 2 !important;
    width: 100% !important;

    /* 텍스트가 오른쪽으로 가는 현상 방지 (세로 정렬 강제) */
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: flex-start !important;
}

/* 2. 회색 박스(.menu-item) 납작하게 누르기 */
.menu-grid .menu-wrapper.wide-menu .menu-item {
    width: 100% !important;

    /* [핵심 수정] 비율을 2.2가 아니라 4.2로 변경! */
    /* 가로가 2배 넓어졌으니, 비율 수치도 2배 커져야 높이가 그대로 유지됩니다. */
    /* (기본 비율 약 2:1 -> 와이드 비율 약 4.2:1) */
    aspect-ratio: 4.2 / 1 !important;

    /* 높이가 튀는 것을 방지하기 위한 초기화 */
    height: auto !important;
    padding: 0 !important;
    margin-bottom: 8px !important;

    /* 내부 아이콘 정렬 */
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;

    font-size: 2rem !important;
}

/* 3. 텍스트 라벨 */
.menu-grid .menu-wrapper.wide-menu .menu-label {
    text-align: center !important;
    width: 100% !important;
    margin-top: 0 !important;
    font-size: 1.0em !important;
    font-weight: bold !important;

    /* 텍스트가 옆으로 붙는 것 방지 */
    display: block !important;
    position: static !important;
}

/* --- 모바일 반응형 --- */
/* 모바일에서는 가로폭이 좁아서 비율을 다시 조정해야 예쁩니다 */
@media (max-width: 600px) {
    .menu-grid .menu-wrapper.wide-menu {
        grid-column: span 2 !important;
    }

    .menu-grid .menu-wrapper.wide-menu .menu-item {
        /* 모바일에서는 그리드 비율이 달라지므로 비율 조정 */
        /* 화면이 좁을 땐 3.5 정도가 적당합니다 */
        aspect-ratio: 3.5 / 1 !important;
        font-size: 1.6em !important;
    }
}
