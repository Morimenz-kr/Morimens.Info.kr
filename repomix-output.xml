<file path="css/pages/links.css">
/* ============================================
   links.html 전용 스타일
   ============================================ */

/* --- 1. 링크 컨테이너 --- */
.link-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 10px;
}

/* --- 2. 카테고리 타이틀 --- */
.category-title {
    color: #ffc107;
    border-bottom: 2px solid #555;
    padding-bottom: 15px;
    margin-bottom: 30px;
    font-size: 1.8em;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 10px;
}

.title-thumb {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    object-fit: cover;
    border: 2px solid #555;
}

/* --- 3. 데이터 없음 상태 --- */
.no-data {
    text-align: center;
    padding: 50px;
    color: #777;
    border: 2px dashed #444;
    border-radius: 10px;
}

/* --- 4. 제보 버튼 섹션 --- */
.report-section {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid #444;
    text-align: center;
    color: #777;
    font-size: 0.9em;
}

.report-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 8px 16px;
    background-color: #333;
    color: #ccc;
    text-decoration: none;
    border-radius: 20px;
    border: 1px solid #555;
    transition: all 0.2s;
    cursor: pointer;
}

.report-btn:hover {
    background-color: #444;
    color: #fff;
    border-color: #ffc107;
}

/* 교환 코드 카드 레이아웃 */
.code-card-container { display: flex; flex-direction: column; gap: 12px; margin-bottom: 30px; }
.code-card {
    background: #2a2a2a; border: 1px solid #444; border-radius: 10px;
    padding: 16px; display: flex; justify-content: space-between; align-items: center;
}
.code-details { flex: 1; text-align: left; }
.code-title { font-weight: bold; font-size: 1.2em; color: #fff; display: block; }
.code-reward { font-size: 0.9em; color: #aaa; }
.code-timer { font-size: 0.8em; color: #ff9f43; margin-top: 4px; font-weight: bold; }
.code-copy-btn {
    background: #42b983; color: white; padding: 8px 16px;
    border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s;
}
.code-copy-btn:hover { background: #33a06f; transform: scale(1.05); }
.code-copy-btn.copied { background: #ffc107; color: #000; }
.section-label { color: #ffc107; margin: 20px 0 10px; font-size: 1.1em; border-left: 4px solid #ffc107; padding-left: 10px; }

/* --- 6. 제보 모달 폼 스타일 --- */
.modal-content {
    width: 90%;
    max-width: 500px;
    background-color: #2c2c2c;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 5px 25px rgba(0, 0, 0, 0.7);
    animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
    0% {
        opacity: 0;
        transform: translateY(-20px);
    }

    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

.form-title {
    color: #ffc107;
    border-bottom: 2px solid #444;
    padding-bottom: 10px;
    margin-top: 0;
}

.form-field-label {
    display: block;
    margin-top: 15px;
    margin-bottom: 5px;
    font-weight: bold;
    color: #ccc;
}

.form-input,
.form-textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #555;
    border-radius: 6px;
    background-color: #383838;
    color: #eee;
    font-size: 1em;
    box-sizing: border-box;
}

.form-input:focus,
.form-textarea:focus {
    outline: none;
    border-color: #ffc107;
}

.form-textarea {
    min-height: 120px;
    max-height: 400px;
    /* 🔧 최대 높이 제한 - 화면 뚫고 내려가는 버그 방지 */
    resize: vertical;
}

.form-submit-btn {
    display: block;
    width: 100%;
    padding: 12px;
    margin-top: 20px;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
}

.form-submit-btn:hover {
    background-color: #0056b3;
}

/* ============================================
   크롬 스타일 폴더형 탭 및 화면 스위칭 로직
   ============================================ */
.chrome-tabs-container {
    display: flex;
    align-items: flex-end;
    margin-bottom: 0;
    border-bottom: 1px solid #444; /* 하단 전체를 가로지르는 기준선 */
    padding-left: 10px;
}

.chrome-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background: #2a2a2e;
    border: 1px solid #444;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    cursor: pointer;
    font-size: 0.95em;
    color: #888;
    margin-bottom: -1px; /* 하단 기준선을 덮기 위한 트릭 */
    transition: all 0.2s;
    font-family: 'Pretendard', sans-serif;
    min-width: 120px; /* 글씨 크기에 맞춰 늘어나게 함 */
}

.chrome-tab:hover:not(.active) {
    background: #333338;
    color: #ccc;
}

.chrome-tab.active {
    background: #38383e;
    color: #ffc107;
    font-weight: bold;
    border-color: #444;
    border-bottom: 1px solid #38383e; /* 활성화 시 하단 선을 지워서 내용물과 연결 */
    z-index: 2;
}

/* 탭 전환 시 나타나는 콘텐츠 화면 (가로 폭은 부모를 따라 고정됨) */
.tab-content {
    display: none; /* 기본적으로 화면에서 완전히 제거됨 */
    animation: fadeInTab 0.3s ease-out;
    padding-top: 25px;
}

.tab-content.active {
    display: block; /* 활성화 시에만 화면 통째로 등장 */
}

@keyframes fadeInTab {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
}

/* 도감 전용 격자 레이아웃 */
.dictionary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 15px;
}
/* ============================================
   명륜 상세 정보 툴팁 디자인
   ============================================ */
.item-tooltip {
    display: none; position: fixed; z-index: 9999; background: rgba(18, 18, 18, 0.95);
    border: 1px solid #777; border-radius: 4px; padding: 12px; max-width: 300px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.8); pointer-events: none; color: #eee; font-size: 0.9rem; line-height: 1.4;
}
.tooltip-title { color: #ffc107; font-weight: bold; margin-bottom: 6px; font-size: 1.1em; border-bottom: 1px solid #444; padding-bottom: 4px; }
.tooltip-desc { color: #ccc; word-break: keep-all; }
.tooltip-tags { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; }
.tooltip-tag { font-size: 0.75em; background: #333; color: #aaa; padding: 2px 6px; border-radius: 4px; }
.tooltip-main-stat { color: #ffc107; margin-bottom: 5px; font-weight: bold; }
.tooltip-effect-desc { color: #ccc; font-size: 0.9em; line-height: 1.4; }

/* 모바일 화면에서는 마우스가 없으므로 터치 시 화면 중앙 하단에 고정되도록 처리 */
@media (max-width: 768px) {
    .item-tooltip {
        position: fixed !important; top: auto !important; bottom: 90px !important;
        left: 50% !important; transform: translateX(-50%) !important;
        width: 90% !important; max-width: none !important;
        background: rgba(25, 25, 30, 0.98); border: 1px solid #ffc107;
        box-shadow: 0 -5px 20px rgba(0,0,0,0.7); text-align: left;
        padding: 15px; z-index: 2000; border-radius: 8px; pointer-events: none;
    }
}
